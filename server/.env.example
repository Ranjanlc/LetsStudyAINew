# PostgreSQL connection (required)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/letsstudyai

# JWT signing secret — use a long random string in production (min 16 characters)
JWT_SECRET=your_jwt_secret_change_me_min_16_chars

# Optional: access token lifetime (default 7d)
# JWT_EXPIRES_IN=7d

# Groq API (optional for AI features)
GROQ_API_KEY=

PORT=3001
